# Copy to .env and fill in. Pipeline runs in DRY-RUN with none of these set.
# --- Script (pick one) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Voice ---
ELEVENLABS_API_KEY=

# --- Visuals (stock b-roll / images) ---
PEXELS_API_KEY=
PIXABAY_API_KEY=

# --- Cloud render (optional alternative to local ffmpeg) ---
SHOTSTACK_API_KEY=
CREATOMATE_API_KEY=

# --- Upload (YouTube Data API v3 OAuth) ---
# Place client_secret.json next to run.py and run `python run.py auth` once.
YOUTUBE_CLIENT_SECRET_FILE=client_secret.json
YOUTUBE_TOKEN_FILE=token.json
